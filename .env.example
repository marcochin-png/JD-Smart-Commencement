# Example environment variables for Smart Commencement
# Required: set your OpenAI-compatible API key
OPENAI_API_KEY=sk-REPLACE_ME

# Optional: change default server port (defaults to 4000)
PORT=4000

# Optional: change model and base URL for non-OpenAI providers
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# Optional: analytics (Umami or compatible) - set both to enable client analytics
# Example: VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
#          VITE_ANALYTICS_WEBSITE_ID=00000000-0000-0000-0000-000000000000
# Leave undefined to disable analytics in dev and production builds
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
